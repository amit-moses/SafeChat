# Firebase (frontend — safe to expose)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Toxicity model (Firebase Storage download URL for model.onnx).
# Leave empty for local dev to load from /public/model/model.onnx.
VITE_MODEL_URL=

# Gemini (server-side only — add to Vercel environment variables)
GEMINI_API_KEY=
